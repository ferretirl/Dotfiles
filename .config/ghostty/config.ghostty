shell-integration-features = no-cursor
theme = noctalia

font-family = CaskaydiaCove NFM 
font-size = 14

background-opacity = 0.87

cursor-style = bar 
cursor-style-blink = false

 window-padding-x = 5
 window-padding-y = 5

confirm-close-surface = false

shell-integration = fish

link-url = true
image-storage-limit = 320000000
