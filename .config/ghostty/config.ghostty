shell-integration-features = no-cursor
theme = noctalia
# gtk-single-instance = true
# working-directory = inherit
# Font
font-family = JetBrains Mono Nerd Font
font-size = 11

# Cursor
cursor-style = bar

# Padding
window-padding-x = 22
window-padding-y = 22

# No close confirmation
confirm-close-surface = false

# Shell
command = fish
