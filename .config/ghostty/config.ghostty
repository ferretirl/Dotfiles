shell-integration-features = no-cursor
theme = noctalia
# gtk-single-instance = true
# working-directory = inherit
# Font
font-family = MesloLGS Nerd Font Mono 
font-size = 12

# Cursor
cursor-style = bar

# Padding
 window-padding-x = 10
 window-padding-y = 10

# No close confirmation
confirm-close-surface = false

# Shell
command = fish
