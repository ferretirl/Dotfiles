//Input file
input {
    keyboard {
        xkb {
            layout "cz,us"
            options "grp:alt_shift_toggle"
        }
        repeat-delay 250
        repeat-rate 35
        numlock true
    }

    mouse {
        // Hyprland sensitivity -0.9 (libinput scale: -1.0 to 1.0)
        accel-speed -0.9
        // Hyprland: follow_mouse=1 → focus follows mouse
    }

    // focus-follows-mouse — niri equivalent
    focus-follows-mouse //max-scroll-amount="10%"
    warp-mouse-to-focus mode="center-xy"
}
