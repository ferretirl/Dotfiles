// ── Layout ───────────────────────────────────────────────────
layout {
    gaps 8
    center-focused-column "never"
    default-column-width { proportion 0.5; }

    focus-ring {
        width 2
        // active-gradient from="#C8DEFF" to="#f18a7c" angle=90
        // inactive-color "#1A2640"
    }

    border {
        off  // using focus-ring instead; enable if you want a persistent border
    }
   //background-color "transparent"
}
